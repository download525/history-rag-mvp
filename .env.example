# Prefer GIGACHAT_CREDENTIALS for normal work: the SDK refreshes short-lived tokens.
# Use GIGACHAT_ACCESS_TOKEN only for quick manual tests.
GIGACHAT_ACCESS_TOKEN=put_your_temporary_access_token_here
GIGACHAT_CREDENTIALS=put_your_authorization_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=true
